# --- Vicket API Configuration ---
# Your private API key (Server-side only)
NUXT_PUBLIC_VICKET_API_KEY=your_private_api_key_here

# Public API URL for client-side requests (Nuxt 4)
NUXT_PUBLIC_VICKET_API_URL=https://api.vicket.app/api/v1

# --- Security ---
# Secret for session management
NUXT_SESSION_PASSWORD=at_least_32_characters_long_password
